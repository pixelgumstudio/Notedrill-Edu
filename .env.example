# Root .env — used by docker-compose.prod.yml on the Hetzner server
# Copy this to .env on the server and fill in the values

# Your domain or IP-based domain (e.g. 65-21-10-45.sslip.io)
DOMAIN=your-domain.com

# Must match the domain above — baked into the Next.js bundle at build time
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1

# MinIO credentials (must match R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY in api/.env)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=choose_a_strong_password_here
